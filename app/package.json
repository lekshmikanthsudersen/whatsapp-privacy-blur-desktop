{
  "name": "whatsapp-privacy-blur",
  "version": "1.0.1",
  "description": "Standalone WhatsApp Web desktop wrapper with privacy blur controls.",
  "main": "src/main.js",
  "author": "Sudersen",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "dist": "electron-builder --win",
    "lint:syntax": "node --check src/main.js && node --check src/preload-whatsapp.js && node --check src/preload-settings.js && node --check src/settings.js && node --check src/first-run.js && node --check src/diagnostics.js && node --check src/security-helpers.js && node --check scripts/after-pack.js && node --check scripts/generate-sbom.js && node --check scripts/generate-release-manifest.js && node --check scripts/verify-fuses.js",
    "test": "npm run lint:syntax && node --test test/*.test.js",
    "sbom": "node scripts/generate-sbom.js",
    "release:manifest": "node scripts/generate-release-manifest.js",
    "verify:fuses": "node scripts/verify-fuses.js",
    "verify:release": "npm run test && npm run build && npm run verify:fuses && npm run sbom && npm run release:manifest"
  },
  "build": {
    "appId": "local.whatsappprivacyblur.app",
    "productName": "WhatsApp Privacy Blur",
    "files": [
      "assets/**/*",
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "afterPack": "scripts/after-pack.js",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}",
      "unpackDirName": "WhatsAppPrivacyBlurPortable"
    },
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WhatsApp Privacy Blur"
    }
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
